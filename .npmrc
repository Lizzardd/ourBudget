# pnpm configuration — Our Budget
# React Native / Expo / Metro need a flat node_modules; pnpm still uses its
# content-addressable store + integrity-checked lockfile underneath.
node-linker=hoisted

# --- Supply-chain hardening ---
# Cooldown: refuse to install any package version published less than this many
# minutes ago (10080 = 7 days). Blocks the typical "publish malicious version,
# gets caught/yanked within days" npm attack window. Lower to 1440 (24h) only if
# a genuinely-needed fresh release is being blocked.
minimum-release-age=10080

# Verify every package's integrity against the store on install (default true,
# pinned explicitly).
verify-store-integrity=true

# Lifecycle (postinstall/build) scripts are BLOCKED by default in pnpm 10+.
# A package may only run build scripts if listed in package.json
# > pnpm.onlyBuiltDependencies. Never enable dangerously-allow-all-builds.
