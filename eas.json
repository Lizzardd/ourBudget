{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://glorious-panda-32.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://glorious-panda-32.convex.site"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://shiny-scorpion-150.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://shiny-scorpion-150.convex.site"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://shiny-scorpion-150.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://shiny-scorpion-150.convex.site"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
