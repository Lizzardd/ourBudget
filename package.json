  "dependencies": {
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.94",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/material-symbols-rounded": "^0.4.50",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-community/datetimepicker": "9.1.0",
    "convex": "^1.42.1",
    "eas-cli": "^20.5.1",
    "expo": "~57.0.4",
    "expo-auth-session": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "~19.2.2",
    "concurrently": "^10.0.3",
    "convex-test": "^0.0.54",
    "playwright": "^1.61.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "convex": "convex dev",
    "convex:deploy": "convex deploy",
    "dev-local": "concurrently -k -n convex,web -c blue,magenta \"convex dev\" \"expo start --web\"",
    "web:build": "expo export -p web",
    "build:android": "eas build -p android --profile preview",
    "build:android:prod": "eas build -p android --profile production",
    "update:android": "EXPO_PUBLIC_USE_RN_FETCH=1 EXPO_PUBLIC_CONVEX_URL=https://shiny-scorpion-150.convex.cloud EXPO_PUBLIC_CONVEX_SITE_URL=https://shiny-scorpion-150.convex.site eas update --channel preview",
    "update:android:prod": "EXPO_PUBLIC_USE_RN_FETCH=1 EXPO_PUBLIC_CONVEX_URL=https://shiny-scorpion-150.convex.cloud EXPO_PUBLIC_CONVEX_SITE_URL=https://shiny-scorpion-150.convex.site eas update --channel production"
  },
  "scriptsInfo": {
    "start": "Expo dev server with the interactive platform picker",
    "android": "Open the app on a connected Android device/emulator (dev)",
    "ios": "Open the app on an iOS simulator (dev)",
    "web": "Local web/PWA dev server (http://localhost:8081)",
    "test": "Run the vitest suite once",
    "typecheck": "Type-check the project with no emit",
    "convex": "Local Convex backend hot-reload (dev deployment)",
    "convex:deploy": "Push schema + functions to the prod Convex deployment",
    "dev-local": "Full local stack: Convex dev backend + Expo web together",
    "web:build": "Static web export (dist/) — verifies a production web build",
    "build:android": "EAS build the OTA-updatable APK (preview channel)",
    "build:android:prod": "EAS build the production APK (production channel)",
    "update:android": "Push an OTA JS/asset update to installed preview APKs",
    "update:android:prod": "Push an OTA update to production APKs"
  },
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  }
}
